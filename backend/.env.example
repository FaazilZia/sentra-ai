x# ============================================================
# Sentra AI — Backend Node.js Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=production  # Options: development | production | test

# --- Database (Supabase/PostgreSQL) ---
# Your Supabase connection string (use the "Session Mode" pooler URL for Render)
# Format: postgresql://<user>:<password>@<host>:<port>/postgres
DATABASE_URL="postgresql://postgres.[project-ref]:[your-password]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres:[your-password]@db.[project-ref].supabase.co:5432/postgres"

# --- JWT Authentication ---
# Use at least 32-character random strings. Generate with: openssl rand -hex 32
JWT_SECRET="replace-with-a-256-bit-random-secret"
REFRESH_SECRET="replace-with-another-256-bit-random-secret"

# --- Token Expiry ---
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# --- CORS ---
# Comma-separated list of allowed frontend origins (no trailing slashes)
FRONTEND_URL="https://sentra-ai-tau.vercel.app,https://sentra-ai.vercel.app,http://localhost:5173"

# --- AI Services ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Organization Scoping ---
# [DEPRECATED] Default organization for demo/dev only. 
# In production, users must have a uniquely provisioned organizationId.
DEFAULT_ORGANIZATION_ID="00000000-0000-0000-0000-000000000001"

# --- Redis (Required in production for rate limiting + background jobs) ---
# Without this, rate limiting falls back to in-memory (not safe for multi-instance deployments)
# and all AI action logs are written synchronously (higher latency per request)
REDIS_URL=redis://localhost:6379

# --- Feature Flags (Optional) ---
# ENABLE_API_KEY_AUTH=true
# RATE_LIMIT_REQUESTS_PER_MINUTE=60

# --- Alerting (Email) ---
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=your-postmark-server-token
SMTP_PASS=your-postmark-server-token
SMTP_FROM="Sentra AI Alerts" <alerts@sentra.ai>
