# PRODUCTION ENVIRONMENT — Never commit this file with real values

# --- Server ---
PORT=3000 # REQUIRED
NODE_ENV=production # REQUIRED

# --- Database ---
DATABASE_URL= # REQUIRED (Supabase Transaction Pooler URL)
DIRECT_URL= # REQUIRED (Supabase Direct Connection URL)

# --- Auth ---
JWT_SECRET= # REQUIRED (min 32 chars, use openssl rand -hex 32)
REFRESH_SECRET= # REQUIRED (min 32 chars, use openssl rand -hex 32)
ACCESS_TOKEN_EXPIRY=15m # OPTIONAL (Default: 15m)
REFRESH_TOKEN_EXPIRY=7d # OPTIONAL (Default: 7d)
FRONTEND_URL= # REQUIRED (Comma-separated list of allowed origins)
ENCRYPTION_KEY= # REQUIRED (32-character key for data encryption)

# --- Redis ---
REDIS_URL= # REQUIRED (Required for rate limiting and async logging)

# --- AI ---
OPENAI_API_KEY= # REQUIRED
OPENAI_MODEL=gpt-4o-mini # OPTIONAL (Default: gpt-4o-mini)

# --- Alerting ---
SMTP_HOST= # REQUIRED (e.g., smtp.postmarkapp.com)
SMTP_PORT=587 # OPTIONAL (Default: 587)
SMTP_USER= # REQUIRED
SMTP_PASS= # REQUIRED
SMTP_FROM= # REQUIRED (e.g., "Sentra AI" <alerts@sentra.ai>)

# --- Feature Flags ---
# ENABLE_API_KEY_AUTH=true # OPTIONAL
# RATE_LIMIT_REQUESTS_PER_MINUTE=60 # OPTIONAL
