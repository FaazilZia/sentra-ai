generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model api_keys {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  name        String
  key_prefix  String
  key_hash    String
  key_type    String    // 'service', 'machine'
  is_active   Boolean
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now())
  companies   companies @relation(fields: [companyId], references: [id])

  @@map("api_keys")
}

model companies {
  id               String       @id @default(uuid())
  name             String
  apiKey           String?      @unique @map("api_key") // Simplified API key if needed
  slug             String       @unique
  is_active        Boolean
  created_at       DateTime     @default(now())
  updated_at       DateTime     @default(now())
  api_keys         api_keys[]
  connectors       connectors[]
  incidents        incidents[]
  policies         policies[]
  policy_versions  policy_versions[]
  users            users[]
  scan_jobs        scan_jobs[]
  logs             logs[]
  ai_agents        ai_agents[]
  drift_alerts     drift_alerts[]

  @@map("companies")
}

model policies {
  id                String            @id @default(uuid())
  companyId         String            @map("company_id")
  name              String
  description       String
  explanation       String?           // Why this policy exists
  compliance        Json?             // Compliance mapping (e.g. ["GDPR", "HIPAA"])
  impact            String?           // Business impact
  enabled           Boolean
  priority          Int
  effect            String            // 'allow', 'deny', etc.
  status            String            // 'draft', 'published'
  rule              Json?             @map("rule") // Specific JSON rule requested
  current_version   Int
  published_version Int?
  scope             Json
  conditions        Json
  obligations       Json
  created_at        DateTime          @default(now())
  updated_at        DateTime          @default(now())
  incidents         incidents[]
  companies         companies         @relation(fields: [companyId], references: [id])
  policy_versions   policy_versions[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("policies")
}

model logs {
  id          String    @id @default(uuid())
  requestId   String?   @map("request_id")
  companyId   String    @map("company_id")
  agent       String    @map("agent")
  action      String
  status      String
  risk        String    @map("risk") // 'low', 'medium', 'high'
  reason      String?
  impact      String?
  latency     Int?      @map("latency")
  timestamp   DateTime  @default(now()) @map("timestamp")
  
  // Extended fields from original ai_activity_logs for compatibility
  explanation String?
  confidence  Float?
  timeline    Json?
  compliance  Json?
  metadata    Json?
  
  // Compliance & Override Fields
  overrideComment   String?   @map("override_comment")
  overriddenBy      String?   @map("overridden_by")
  overrideTimestamp DateTime? @map("override_timestamp")
  isPendingApproval Boolean   @default(false) @map("is_pending_approval")
  approvedBy        String?   @map("approved_by")
  
  companies   companies @relation(fields: [companyId], references: [id])

  @@index([companyId, timestamp])
  @@map("logs")
}

model incidents {
  id               String    @id @default(uuid())
  companyId        String    @map("company_id")
  agent_id         String
  policy_id        String?
  severity         Int
  action           String
  details          String
  prompt_excerpt   String
  response_excerpt String
  event_metadata   Json
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())
  status           String    @default("unresolved")
  user_id          String?
  resolved_by_id   String?
  resolved_at      DateTime?
  policies         policies? @relation(fields: [policy_id], references: [id])
  companies        companies @relation(fields: [companyId], references: [id])
  user             users?    @relation("IncidentAuthor", fields: [user_id], references: [id])
  resolved_by      users?    @relation("IncidentResolver", fields: [resolved_by_id], references: [id])

  @@map("incidents")
}

model policy_versions {
  id                    String   @id @default(uuid())
  policy_id             String
  companyId             String   @map("company_id")
  version               Int
  name                  String
  description           String
  enabled               Boolean
  priority              Int
  effect                String
  status                String
  scope                 Json
  conditions            Json
  obligations           Json
  is_published_snapshot Boolean
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())
  policies              policies @relation(fields: [policy_id], references: [id])
  companies             companies @relation(fields: [companyId], references: [id])

  @@unique([policy_id, version])
  @@map("policy_versions")
}

model ai_agents {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  name        String
  model       String
  permissions Json      // List of permissions (email, API, DB)
  status      String    // 'active', 'inactive'
  metadata    Json?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now())
  companies   companies @relation(fields: [companyId], references: [id])
  dependencies ai_dependencies[]

  @@map("ai_agents")
}

model ai_dependencies {
  id          String    @id @default(uuid())
  agentId     String    @map("agent_id")
  targetType  String    // 'API', 'Database', 'External Service'
  targetName  String
  description String?
  created_at  DateTime  @default(now())
  agent       ai_agents @relation(fields: [agentId], references: [id])

  @@map("ai_dependencies")
}

model drift_alerts {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  agentId     String    @map("agent_id")
  type        String    // 'new_api', 'frequency', 'unusual_behavior'
  severity    String    // 'low', 'medium', 'high'
  description String
  status      String    @default("open") // 'open', 'resolved'
  timestamp   DateTime  @default(now())
  companies   companies @relation(fields: [companyId], references: [id])

  @@map("drift_alerts")
}

model connectors {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  name         String
  type         String   // 'sql', 'gdrive', 's3', 'local'
  config       Json     
  status       String
  last_scan_at String?
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())
  companies    companies @relation(fields: [companyId], references: [id])

  @@map("connectors")
}

model scan_jobs {
  id                 String   @id @default(uuid())
  companyId          String   @map("company_id")
  phase              String
  progress           Int      @default(0)
  incidents_detected Int      @default(0)
  sources_scanned    Int      @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now())
  companies          companies @relation(fields: [companyId], references: [id])

  @@map("scan_jobs")
}

model users {
  id              String            @id @default(uuid())
  companyId       String            @map("company_id")
  email           String            @unique
  full_name       String
  employeeId      String?           @unique @map("employee_id")
  password_hash   String
  role            String            @default("USER") // 'USER', 'ADMIN', 'REVIEWER'
  is_active       Boolean
  created_at      DateTime          @default(now())
  updated_at      DateTime          @default(now())
  incidents_created incidents[] @relation("IncidentAuthor")
  incidents_resolved incidents[] @relation("IncidentResolver")
  consent_records consent_records[]
  requests        requests[]
  refresh_tokens  RefreshToken[]
  companies       companies           @relation(fields: [companyId], references: [id])

  @@map("users")
}

model consent_records {
  id             String   @id @default(uuid())
  user_id        String
  action         String
  notice_version String
  hashing_chain  String
  metadata_json  Json
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now())
  users          users    @relation(fields: [user_id], references: [id])
}

model requests {
  id         String   @id @default(uuid())
  user_id    String
  prompt     String
  response   String
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id])
}

model roles {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
}

model user_roles {
  id         String   @id @default(uuid())
  user_id    String
  role_id    String
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      users    @relation(fields: [userId], references: [id])
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}


