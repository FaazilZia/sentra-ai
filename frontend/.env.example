# ============================================================
# Sentra AI — Frontend React Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- API Configuration ---
# The backend origin or full /api base for the Node.js API.
# Local default should be http://localhost:3000/api.
VITE_API_BASE_URL="http://localhost:3000/api"

# --- Supabase Configuration (Legacy/Auth) ---
# Used for authentication and database direct access if needed.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# --- Feature Flags ---
# Set to 'true' to bypass authentication for development (NOT recommended for production)
VITE_BYPASS_AUTH="false"
