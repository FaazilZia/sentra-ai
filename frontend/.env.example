# ============================================================
# Sentra AI — Frontend React Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- API Configuration ---
# The base URL for the backend Node.js API. 
# Do NOT include a trailing slash.
VITE_API_BASE_URL="https://sentra-backend-node.onrender.com/api"

# --- Supabase Configuration (Legacy/Auth) ---
# Used for authentication and database direct access if needed.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# --- Feature Flags ---
# Set to 'true' to bypass authentication for development (NOT recommended for production)
VITE_BYPASS_AUTH="false"
