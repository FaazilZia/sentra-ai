PORT=5001
NODE_ENV=production

# Database Connection (Supabase/PostgreSQL)
# For Render, this is provided automatically in the Environment tab
DATABASE_URL="postgresql://postgres.xxx:xxx@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# JWT Secret Keys
# For Render, these should be set as Environment Variables
JWT_SECRET="your-256-bit-secret-here"
REFRESH_SECRET="your-refresh-secret-here"

# Frontend URL for CORS (comma-separated list for multiple environments)
FRONTEND_URL="https://sentra-ai.vercel.app,http://localhost:5173"

# Auth Token Expiry
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
