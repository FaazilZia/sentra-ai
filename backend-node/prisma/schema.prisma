generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model api_keys {
  id         String   @id @default(uuid())
  tenant_id  String
  name       String
  key_prefix String
  key_hash   String
  key_type   String   // 'service', 'machine'
  is_active  Boolean
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  tenants    tenants  @relation(fields: [tenant_id], references: [id])
}

model connectors {
  id           String   @id @default(uuid())
  tenant_id    String
  name         String
  type         String   // 'sql', 'gdrive', 's3', 'local'
  config       Json     
  status       String
  last_scan_at String?
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())
  tenants      tenants  @relation(fields: [tenant_id], references: [id])
}

model consent_records {
  id             String   @id @default(uuid())
  user_id        String
  action         String
  notice_version String
  hashing_chain  String
  metadata_json  Json
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now())
  users          users    @relation(fields: [user_id], references: [id])
}

model incidents {
  id               String    @id @default(uuid())
  tenant_id        String
  agent_id         String
  policy_id        String?
  severity         Int
  action           String
  details          String
  prompt_excerpt   String
  response_excerpt String
  event_metadata   Json
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())
  status           String    @default("unresolved")
  user_id          String?
  resolved_by_id   String?
  resolved_at      DateTime?
  policies         policies? @relation(fields: [policy_id], references: [id])
  tenants          tenants   @relation(fields: [tenant_id], references: [id])
  user             users?    @relation("IncidentAuthor", fields: [user_id], references: [id])
  resolved_by      users?    @relation("IncidentResolver", fields: [resolved_by_id], references: [id])
}

model policies {
  id                String            @id @default(uuid())
  tenant_id         String
  name              String
  description       String
  enabled           Boolean
  priority          Int
  effect            String            // 'allow', 'deny', etc.
  status            String            // 'draft', 'published'
  current_version   Int
  published_version Int?
  scope             Json
  conditions        Json
  obligations       Json
  created_at        DateTime          @default(now())
  updated_at        DateTime          @default(now())
  incidents         incidents[]
  tenants           tenants           @relation(fields: [tenant_id], references: [id])
  policy_versions   policy_versions[]

  @@unique([tenant_id, name])
}

model policy_versions {
  id                    String   @id @default(uuid())
  policy_id             String
  tenant_id             String
  version               Int
  name                  String
  description           String
  enabled               Boolean
  priority              Int
  effect                String
  status                String
  scope                 Json
  conditions            Json
  obligations           Json
  is_published_snapshot Boolean
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())
  policies              policies @relation(fields: [policy_id], references: [id])
  tenants               tenants  @relation(fields: [tenant_id], references: [id])

  @@unique([policy_id, version])
}

model requests {
  id         String   @id @default(uuid())
  user_id    String
  prompt     String
  response   String
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id])
}

model roles {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
}

model tenants {
  id               String             @id @default(uuid())
  name             String
  slug             String             @unique
  is_active        Boolean
  created_at       DateTime           @default(now())
  updated_at       DateTime           @default(now())
  api_keys         api_keys[]
  connectors       connectors[]
  incidents        incidents[]
  policies         policies[]
  policy_versions  policy_versions[]
  users            users[]
  scan_jobs        scan_jobs[]
  ai_activity_logs ai_activity_logs[]
}

model user_roles {
  id         String   @id @default(uuid())
  user_id    String
  role_id    String
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
}

model users {
  id              String            @id @default(uuid())
  tenant_id       String
  email           String            @unique
  full_name       String
  password_hash   String
  role            String            @default("USER")
  is_active       Boolean
  created_at      DateTime          @default(now())
  updated_at      DateTime          @default(now())
  incidents_created incidents[] @relation("IncidentAuthor")
  incidents_resolved incidents[] @relation("IncidentResolver")
  consent_records consent_records[]
  requests        requests[]
  refresh_tokens  RefreshToken[]
  tenants         tenants           @relation(fields: [tenant_id], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      users    @relation(fields: [userId], references: [id])
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model scan_jobs {
  id                 String   @id @default(uuid())
  tenant_id          String
  phase              String
  progress           Int      @default(0)
  incidents_detected Int      @default(0)
  sources_scanned    Int      @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now())
  tenants            tenants  @relation(fields: [tenant_id], references: [id])
}

model ai_activity_logs {
  id         String   @id @default(uuid())
  tenant_id  String
  agent_id   String
  action     String
  status     String
  risk_score String
  reason     String?
  metadata   Json?
  created_at DateTime @default(now())
  tenants    tenants  @relation(fields: [tenant_id], references: [id])
}
