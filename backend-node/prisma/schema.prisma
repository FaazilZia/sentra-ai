generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



model api_keys {
  tenant_id  String       @db.Uuid
  name       String       @db.VarChar(255)
  key_prefix String       @db.VarChar(32)
  key_hash   String       @db.VarChar(255)
  key_type   api_key_type
  is_active  Boolean
  id         String       @id @db.Uuid
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  updated_at DateTime     @default(now()) @db.Timestamptz(6)
  tenants    tenants      @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([key_prefix], map: "ix_api_keys_key_prefix")
  @@index([tenant_id], map: "ix_api_keys_tenant_id")
}

model connectors {
  tenant_id    String        @db.Uuid
  name         String        @db.VarChar(255)
  type         connectortype
  config       Json          @db.Json
  status       String        @db.VarChar(50)
  last_scan_at String?       @db.VarChar(50)
  id           String        @id @db.Uuid
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  updated_at   DateTime      @default(now()) @db.Timestamptz(6)
  tenants      tenants       @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenant_id], map: "ix_connectors_tenant_id")
}

model consent_records {
  user_id        String   @db.Uuid
  action         String   @db.VarChar(20)
  notice_version String   @db.VarChar(50)
  hashing_chain  String   @db.VarChar(64)
  metadata_json  Json     @db.Json
  id             String   @id @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)
  users          users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([hashing_chain], map: "ix_consent_records_hashing_chain")
  @@index([user_id], map: "ix_consent_records_user_id")
}

model incidents {
  tenant_id                             String    @db.Uuid
  agent_id                              String    @db.VarChar(255)
  policy_id                             String?   @db.Uuid
  severity                              Int
  action                                String    @db.VarChar(255)
  details                               String    @db.VarChar(1000)
  prompt_excerpt                        String    @db.VarChar(1000)
  response_excerpt                      String    @db.VarChar(1000)
  event_metadata                        Json      @db.Json
  id                                    String    @id @db.Uuid
  created_at                            DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                            DateTime  @default(now()) @db.Timestamptz(6)
  status                                String    @default("unresolved") @db.VarChar(50)
  user_id                               String?   @db.Uuid
  resolved_by_id                        String?   @db.Uuid
  resolved_at                           DateTime? @db.Timestamptz(6)
  policies                              policies? @relation(fields: [policy_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_incidents_resolved_by_idTousers users?    @relation("incidents_resolved_by_idTousers", fields: [resolved_by_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants                               tenants   @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_incidents_user_idTousers        users?    @relation("incidents_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([agent_id], map: "ix_incidents_agent_id")
  @@index([policy_id], map: "ix_incidents_policy_id")
  @@index([tenant_id], map: "ix_incidents_tenant_id")
}

model policies {
  tenant_id         String            @db.Uuid
  name              String            @db.VarChar(255)
  description       String            @db.VarChar(1000)
  enabled           Boolean
  priority          Int
  effect            policy_effect
  status            policy_status
  current_version   Int
  published_version Int?
  scope             Json              @db.Json
  conditions        Json              @db.Json
  obligations       Json              @db.Json
  id                String            @id @db.Uuid
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime          @default(now()) @db.Timestamptz(6)
  incidents         incidents[]
  tenants           tenants           @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  policy_versions   policy_versions[]

  @@unique([tenant_id, name], map: "uq_policy_name_per_tenant")
  @@index([effect], map: "ix_policies_effect")
  @@index([priority], map: "ix_policies_priority")
  @@index([status], map: "ix_policies_status")
  @@index([tenant_id], map: "ix_policies_tenant_id")
}

model policy_versions {
  policy_id             String        @db.Uuid
  tenant_id             String        @db.Uuid
  version               Int
  name                  String        @db.VarChar(255)
  description           String        @db.VarChar(1000)
  enabled               Boolean
  priority              Int
  effect                policy_effect
  status                policy_status
  scope                 Json          @db.Json
  conditions            Json          @db.Json
  obligations           Json          @db.Json
  is_published_snapshot Boolean
  id                    String        @id @db.Uuid
  created_at            DateTime      @default(now()) @db.Timestamptz(6)
  updated_at            DateTime      @default(now()) @db.Timestamptz(6)
  policies              policies      @relation(fields: [policy_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants               tenants       @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([policy_id, version], map: "uq_policy_version_number")
  @@index([policy_id], map: "ix_policy_versions_policy_id")
  @@index([tenant_id], map: "ix_policy_versions_tenant_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model requests {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  prompt     String
  response   String
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model roles {
  name        role_name    @unique
  description String       @db.VarChar(255)
  id          String       @id @db.Uuid
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  updated_at  DateTime     @default(now()) @db.Timestamptz(6)
  user_roles  user_roles[]
}

model tenants {
  name            String            @db.VarChar(255)
  slug            String            @unique(map: "ix_tenants_slug") @db.VarChar(100)
  is_active       Boolean
  id              String            @id @db.Uuid
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  api_keys        api_keys[]
  connectors      connectors[]
  incidents       incidents[]
  policies        policies[]
  policy_versions policy_versions[]
  users           users[]
  scan_jobs       scan_jobs[]
}

model user_roles {
  user_id    String   @db.Uuid
  role_id    String   @db.Uuid
  id         String   @id @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  roles      roles    @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, role_id], map: "uq_user_role_assignment")
  @@index([role_id], map: "ix_user_roles_role_id")
  @@index([user_id], map: "ix_user_roles_user_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  tenant_id                                 String            @db.Uuid
  email                                     String            @unique(map: "ix_users_email") @db.VarChar(320)
  full_name                                 String            @db.VarChar(255)
  password_hash                             String            @db.VarChar(255)
  role                                      String            @default("USER") @db.VarChar(50)
  is_active                                 Boolean
  id                                        String            @id @db.Uuid
  created_at                                DateTime          @default(now()) @db.Timestamptz(6)
  updated_at                                DateTime          @default(now()) @db.Timestamptz(6)
  consent_records                           consent_records[]
  incidents_incidents_resolved_by_idTousers incidents[]       @relation("incidents_resolved_by_idTousers")
  incidents_incidents_user_idTousers        incidents[]       @relation("incidents_user_idTousers")
  requests                                  requests[]
  user_roles                                user_roles[]
  refresh_tokens                            RefreshToken[]
  tenants                                   tenants           @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenant_id], map: "ix_users_tenant_id")
}

enum api_key_type {
  service
  machine
}

enum connectortype {
  sql
  gdrive
  s3
  local
}

enum policy_effect {
  allow
  deny
  mask
  redact
  require_approval
  rate_limit
}

enum policy_status {
  draft
  published
  archived
}

enum role_name {
  admin
  analyst
  auditor
  approver
  viewer
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@map("refresh_tokens")
}

model scan_jobs {
  id                 String   @id @db.Uuid
  tenant_id          String   @db.Uuid
  phase              String   @db.VarChar(20) // IDLE, PROCESSING, SUCCESS, FAILED
  progress           Int      @default(0)
  incidents_detected Int      @default(0)
  sources_scanned    Int      @default(0)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @db.Timestamptz(6)
  tenants            tenants  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id], map: "ix_scan_jobs_tenant_id")
}
